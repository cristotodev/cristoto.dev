---
import ButtonIcon from "../components/ButtonIcon.astro";
import { Icon } from 'astro-icon/components'
---

<div class="flex gap-4 mb-4">
    <img
        src="https://res.cloudinary.com/cristotodev/image/upload/v1716970755/cristotodev/blog/cara_cavxwb.webp"
        alt="Cristo Estévez"
        class="rounded-full shadow-lg size-16"
    />
</div>
<div>
    <h1
        class="text-4xl font-bold text-gray-800 sm:text-5xl animate-bounce-fade-in animate-delay-100 animate-duration-slow"
    >
        Hey, soy cristotodev &#128587;
    </h1>
    <p
        class="mt-6 text-xl text-gray-800  [&>strong]:text-yellow-500 [&>strong]:font-semibold"
    >
        +6 años de experiencia. <strong
            >Desarrollador de Software, Formador y Creador de Contenido sobre Programación</strong
        > de Tenerife, España 🇪🇸.
    </p>
    <nav class="flex flex-wrap gap-4 mt-8">
        <ButtonIcon text="Contáctame" url="mailto:cristotodev@outlook.com">
            <Icon name="email" width={24} height={24}/>
        </ButtonIcon>
        <ButtonIcon text="Linkedin" url="https://es.linkedin.com/in/cristotodev">
            <Icon name="linkedin" width={24} height={24}/>
        </ButtonIcon>
        <ButtonIcon text="GitHub" url="https://github.com/cristotodev">
            <Icon name="github" width={24} height={24}/>
        </ButtonIcon>
    </nav>
</div>
